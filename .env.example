VELIB_BASE_URL=https://velib-metropole-opendata.smovengo.cloud/opendata/Velib_Metropole
COLLECTION_INTERVAL_MINUTES=5
DATA_DIR=data
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
MODEL_DIR=models
POSTGRES_URL=postgresql+psycopg://velib:velib@postgres:5432/velib
MONGO_URL=mongodb://mongo:27017/
MONGO_DATABASE=velib
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
DEFAULT_LATITUDE=48.8566
DEFAULT_LONGITUDE=2.3522
ALERT_THRESHOLD_BIKES=2
ALERT_THRESHOLD_DOCKS=2
